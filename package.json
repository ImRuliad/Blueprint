{
	"name": "blueprint-db",
	"version": "0.1.0",
	"description": "Database GUI for SQLite, PostgreSQL, MySQL, and MongoDB",
	"private": true,
	"type": "module",
	"bin": {
		"blueprint": "./bin/cli.ts"
	},
	"files": ["build/", "drizzle/", "bin/"],
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "bun run bin/cli.ts",
		"build:all": "bun run build",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"prepublishOnly": "bun run build:all",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"devDependencies": {
		"@lucide/svelte": "^1.20.0",
		"@playwright/test": "^1.61.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@types/pg": "^8.20.0",
		"@types/ssh2": "^1.15.5",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@codemirror/lang-sql": "^6.10.0",
		"@codemirror/state": "^6.6.0",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.43.1",
		"@fontsource/geist-mono": "^5.2.8",
		"@fontsource/geist-sans": "^5.2.5",
		"codemirror": "^6.0.2",
		"drizzle-orm": "^0.45.2",
		"mongodb": "^7.3.0",
		"mysql2": "^3.22.5",
		"pg": "^8.22.0",
		"ssh2": "^1.17.0"
	}
}
